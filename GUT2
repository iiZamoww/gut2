local collectTargets = {
    { flag = function() return plasmaLoop end, folder = workspace.Plasma and workspace.Plasma.SpawnedPlasma, partName = "Plasma" },
    { flag = function() return gravitonLoop end, folder = workspace.EventHorizon and workspace.EventHorizon.spawned, partName = "Graviton" },
    { flag = function() return starLoop end, folder = workspace.StarryGround and workspace.StarryGround.StarParticles, partName = "StarParticle" },
}

local function handleFolder(folder, partName)
    if not folder then return end
    for _, part in ipairs(folder:GetChildren()) do
        if part.Name == partName and part:IsA("BasePart") then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                pcall(function()
                    firetouchinterest(part, root, 0)
                    firetouchinterest(part, root, 1)
                end)
            end
        end
    end
end

task.spawn(function()
    while true do
        for _, target in ipairs(collectTargets) do
            if target.flag() and target.folder then
                handleFolder(target.folder, target.partName)
            end
        end
        task.wait(0.001)
    end
end)

task.spawn(function()
