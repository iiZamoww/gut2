-- Get the number from CubifyX name
local function getCubifyNumber(modelName)
    local num = modelName:match("Cubify(%d+)")
    return num and tonumber(num) or 0
end

-- Get the highest existing Cubify number
local function getHighestExistingCubifyNumber()
    local highest = 0
    local cubifyFolder = workspace:FindFirstChild("Buttons") and workspace.Buttons:FindFirstChild("Cubify")
    if cubifyFolder then
        for _, model in ipairs(cubifyFolder:GetChildren()) do
            if model:IsA("Model") and model.Name:match("Cubify%d+") then
                local num = getCubifyNumber(model.Name)
                if num > highest then
                    highest = num
                end
            end
        end
    end
    return highest
end

task.spawn(function() while true do if quantumEnergyLoop then masterGUI:FireServer("UpdateNihilized", "QuantumEnergy") end task.wait(0.1) end end)

task.spawn(function()
    while true do
        if cubifyLoop then
            local cubifyFolder = workspace:FindFirstChild("Buttons") and workspace.Buttons:FindFirstChild("Cubify")
            if cubifyFolder then
                local totalUpgrades = 0
                local clickedThisCycle = 0
                
                -- First pass: count total upgrades
                for _, model in ipairs(cubifyFolder:GetChildren()) do
                    if model:IsA("Model") and model.Name:match("Cubify%d+") then
                        totalUpgrades = totalUpgrades + 1
                    end
                end
                
                -- Second pass: click upgrades
                for _, model in ipairs(cubifyFolder:GetChildren()) do
                    if model:IsA("Model") and model.Name:match("Cubify%d+") then
                        local mainPart = model:FindFirstChild("MainPart")
                        if mainPart and mainPart:IsA("BasePart") then
                            local clickDetector = mainPart:FindFirstChild("ClickDetector")
                            if clickDetector then
                                pcall(function()
                                    fireclickdetector(clickDetector, 15)
                                    local currentNum = getCubifyNumber(model.Name)
                                    if currentNum > highestCubifyNumber then
                                        highestCubifyNumber = currentNum
                                        print("New highest Cubify:", highestCubifyNumber)
                                    end
                                    clickedThisCycle = clickedThisCycle + 1
                                end)
                            end
                        end
                    end
                    task.wait(0.02)
                end
                
                -- Check if we've clicked all upgrades and reached the highest one
                local highestExisting = getHighestExistingCubifyNumber()
                
                if clickedThisCycle >= totalUpgrades and highestCubifyNumber >= highestExisting then
                    cubifyLoop = false
                    if cubifyToggleRef then
                        cubifyToggleRef:SetValue(false)
                    end
                    print("All Cubify upgrades bought! Toggle turned off.")
                end
            end
        end
        task.wait(0.05)
    end
end)

