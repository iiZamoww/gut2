task.spawn(function()
    while true do
        if cubifyLoop then
            local cubifyFolder = workspace:FindFirstChild("Buttons") and workspace.Buttons:FindFirstChild("Cubify")
            if cubifyFolder then
                for _, model in ipairs(cubifyFolder:GetChildren()) do
                    if model:IsA("Model") and model.Name:match("Cubify%d+") then
                        local mainPart = model:FindFirstChild("MainPart")
                        if mainPart and mainPart:IsA("BasePart") then
                            local clickDetector = mainPart:FindFirstChild("ClickDetector")
                            if clickDetector then
                                -- check if already maxed by color
                                if mainPart.Color ~= Color3.fromRGB(27, 26, 5) then
                                    pcall(function()
                                        fireclickdetector(clickDetector, 15)
                                    end)
                                end
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.05)
    end
end)

local collectTargets = {
    { flag = function() return plasmaLoop end, folder = function() return workspace:FindFirstChild("Plasma") and workspace.Plasma:FindFirstChild("SpawnedPlasma") end, partName = "Plasma" },
    { flag = function() return gravitonLoop end, folder = function() return workspace:FindFirstChild("EventHorizon") and workspace.EventHorizon:FindFirstChild("spawned") end, partName = "Graviton" },
    { flag = function() return starLoop end, folder = function() return workspace:FindFirstChild("StarryGround") and workspace.StarryGround:FindFirstChild("StarParticles") end, partName = "StarParticle" },
}

local function handleFolder(folder, partName)
    if not folder then return end
    for _, part in ipairs(folder:GetChildren()) do
        if part.Name == partName and part:IsA("BasePart") then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                pcall(function()
                    firetouchinterest(part, root, 0)
                    firetouchinterest(part, root, 1)
                end)
            end
        end
    end
end

task.spawn(function()
    while true do
        for _, target in ipairs(collectTargets) do
            if target.flag() then
                handleFolder(target.folder(), target.partName)
            end
        end
        task.wait(0.001)
    end
end)

