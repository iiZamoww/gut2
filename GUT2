end)

local function handleCurrPart(part)
    if not part:IsA("BasePart") then return end
    local currFolder = workspace.Cube.curr
    while part and part.Parent == currFolder do
        pcall(function()
            part.Velocity = Vector3.new(0, 0, 0)
            part.RotVelocity = Vector3.new(0, 0, 0)
            part.CanCollide = false
            part.CastShadow = false
            part.Anchored = true
        end)
        local currentRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if currentRoot then
            pcall(function()
                part.CFrame = CFrame.new(currentRoot.Position + Vector3.new(0, 5, 0))
            end)
        end
        task.wait(0.1)
        local clickDetector = part:FindFirstChild("ClickDetector")
        if clickDetector then
            pcall(function() fireclickdetector(clickDetector, 15) end)
        end
        task.wait(0.2)
    end
end

task.spawn(function()
    while true do
        if currLoop then
            local currFolder = workspace.Cube.curr
            for _, part in ipairs(currFolder:GetChildren()) do
                task.spawn(function() handleCurrPart(part) end)
            end
            currFolder.ChildAdded:Connect(function(newPart)
                if currLoop then
                    task.spawn(function() handleCurrPart(newPart) end)
                end
            end)
        end
        task.wait(1)
    end
end)
